# ===========================
# Server
# ===========================
PORT=8080

# ===========================
# Application URLs
# ===========================
SHOPKART_BASE_URL=http://localhost:8080
SHOPKART_API_BASE_URL=http://localhost:8080/api

# ===========================
# Database
# ===========================
DB_JDBC_URL=jdbc:mysql://localhost:3306/shopkart
DB_USER=shopkart_user
DB_PASSWORD=YourPassword@123
DB_CONNECTION_TIMEOUT_MS=10000

# ===========================
# Browser
# ===========================
BROWSER=chrome
HEADLESS=false
BROWSER_SIZE=1920x1080
UI_TIMEOUT_MS=10000

# ===========================
# Security
# ===========================
SHOPKART_TOKEN_SECRET=12345678901234567890123456789012

# ===========================
# Test Users
# ===========================
SHOPKART_ALICE_PASSWORD=Shopkart_alice
SHOPKART_BOB_PASSWORD=Shopkart_bob
SHOPKART_CAROL_PASSWORD=Shopkart_carol

# ===========================
# Test Configuration
# ===========================
SHOPKART_API_DELAY_MS=0